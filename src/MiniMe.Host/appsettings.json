{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AgentFramework": {
    "Agents": [
      {
        "Name": "Echo",
        "Enabled": true,
        "IntervalSeconds": 30,
        "Credentials": {},
        "Settings": {
          "Message": "Hello from the Mini-Me agent framework!"
        }
      },
      {
        "Name": "TeamWinsGratitude",
        "Enabled": false,
        "IntervalSeconds": 86400,
        "Credentials": {
          "TenantId": "<your-azure-ad-tenant-id>",
          "ClientId": "<your-azure-ad-client-id>",
          "ClientSecret": "<your-azure-ad-client-secret>"
        },
        "Settings": {
          "RecipientEmail": "<team-distribution-list-or-email>",
          "TeamName": "My Team",
          "CopilotPrompt": "Summarize the big wins and accomplishments for my team from the past week.",
          "SenderUserId": ""
        }
      }
    ]
  }
}
